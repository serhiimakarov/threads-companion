# Threads App Credentials (from developers.facebook.com)
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=https://threads.local/auth/callback

# Access Tokens (Generated via 'manage.py auth')
# Bot will automatically try to upgrade these to 60-day tokens
THREADS_ACCESS_TOKEN_SOURCE=
THREADS_ACCESS_TOKEN_TARGET=

# AI Configuration
# AI_PROVIDER can be 'gemini' or 'ollama'
AI_PROVIDER=gemini
GEMINI_API_KEY=

# Ollama Configuration (for local models)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_HOST=http://localhost:11434

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database Configuration
DATABASE_PATH=data/threads_scheduler.db
IMGBB_API_KEY=
